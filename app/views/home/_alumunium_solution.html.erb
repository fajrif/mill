<!-- start aluminium solutions section -->
<section class="aluminium-solutions-section" id="aluminium-solutions">
  <!-- pin-track gives the scroll distance; the stage sticks (CSS sticky) so the
       section never leaves normal flow — it releases seamlessly, with no
       position:fixed swap, unlike GSAP's pin. -->
  <div class="aluminium-pin-track">
    <div class="aluminium-stage">
        <div class="container-fluid aluminium-orbit-outer">
        <div class="aluminium-orbit" id="portrait-images-row">
            <div class="aluminium-image-wrapper floating-card aluminium-orbit-slot-1">
                <div class="aluminium-image">
                    <%= image_tag('new-images/image-1.png', alt: 'Premium aluminium sliding doors', class: 'img-fluid') %>
                </div>
            </div>
            <div class="aluminium-image-wrapper floating-card aluminium-orbit-slot-2">
                <div class="aluminium-image">
                    <%= image_tag('new-images/image-5.png', alt: 'Expansive aluminium glass walls', class: 'img-fluid') %>
                </div>
            </div>
            <div class="aluminium-image-wrapper floating-card aluminium-orbit-slot-3">
                <div class="aluminium-image">
                    <%= image_tag('new-images/image-6.png', alt: 'Minimalist aluminium window frames', class: 'img-fluid') %>
                </div>
            </div>
            <div class="aluminium-image-wrapper floating-card aluminium-orbit-slot-4">
                <div class="aluminium-image">
                    <%= image_tag('new-images/image-2.png', alt: 'Aluminium framed balcony detail', class: 'img-fluid') %>
                </div>
            </div>

            <!-- Center: Text Description -->
            <div class="aluminium-orbit-text">
                <!-- Text Parallax Area -->
                <div class="text-parallax-wrapper">
                    <div class="text-parallax-sticky">
                        <div class="text-parallax-container" data-text-parallax>
                            <div class="text-parallax-line">
                                <span data-parallax-text>Aluminium solutions that </span><span data-parallax-text class="parallax-italic">seamlessly</span><span data-parallax-text> extend your living</span>
                            </div>
                            <div class="text-parallax-line">
                                <span data-parallax-text>space, framing panoramic views while bringing </span><span data-parallax-text class="parallax-italic">light</span><span data-parallax-text>,</span>
                            </div>
                            <div class="text-parallax-line">
                                <span data-parallax-text class="parallax-italic">openness</span><span data-parallax-text>, and </span><span data-parallax-text class="parallax-italic">comfort</span><span data-parallax-text> into your everyday life.</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="aluminium-image-wrapper floating-card aluminium-orbit-slot-5">
                <div class="aluminium-image">
                    <%= image_tag('new-images/image-4.png', alt: 'Modern aluminium window solution with panoramic views', class: 'img-fluid') %>
                </div>
            </div>
            <div class="aluminium-image-wrapper floating-card aluminium-orbit-slot-6">
                <div class="aluminium-image">
                    <%= image_tag('new-images/image-3.png', alt: 'Sleek aluminium framing for contemporary architecture', class: 'img-fluid') %>
                </div>
            </div>
        </div>
        </div>
    </div>
  </div>
</section>
<!-- end aluminium solutions section -->

<% content_for :tail do %>
<script>
(function() {
  'use strict';

  // Check if GSAP is available
  if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') {
    console.warn('Aluminium Solutions: GSAP or ScrollTrigger not loaded');
    return;
  }

  gsap.registerPlugin(ScrollTrigger);

  var section = document.getElementById('aluminium-solutions');
  var orbit = document.querySelector('.aluminium-orbit');
  var track = document.querySelector('.aluminium-pin-track');
  if (!section || !orbit || !track) return;

  // Split the center text into individual character spans (structure only).
  var textElements = document.querySelectorAll('[data-parallax-text]');
  var allChars = [];
  textElements.forEach(function(el) {
    var text = el.textContent;
    el.textContent = '';
    el.setAttribute('aria-label', text);

    for (var i = 0; i < text.length; i++) {
      var charSpan = document.createElement('span');
      charSpan.className = 'char';

      if (text[i] === ' ') {
        charSpan.innerHTML = '&nbsp;';
        charSpan.classList.add('char--space');
      } else {
        charSpan.textContent = text[i];
      }

      el.appendChild(charSpan);
      allChars.push(charSpan);
    }
  });

  var imageWrappers = gsap.utils.toArray('.aluminium-image-wrapper');

  // Respect reduced motion: show the final layout, no animation, no pin.
  var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (prefersReducedMotion) {
    gsap.set(allChars, { opacity: 1 });
    return;
  }

  function randomBetween(min, max) {
    return Math.random() * (max - min) + min;
  }

  // Precompute a stable scattered start state for each character.
  var scatter = allChars.map(function() {
    return {
      x: randomBetween(-300, 300),
      y: randomBetween(-150, 150),
      z: randomBetween(-500, 100),
      rotateY: randomBetween(-120, 120),
      rotateX: randomBetween(-30, 30),
      scale: randomBetween(0.2, 0.6)
    };
  });

  var mm = gsap.matchMedia();

  // Desktop / wide: the stage is pinned via CSS position:sticky, so we DON'T
  // use GSAP's pin (which would swap the section to position:fixed and back,
  // causing the jarring "replace" on release). Instead we just scrub the
  // timeline against the pin-track's scroll range while the stage stays stuck.
  // Images rise in from below one-by-one into their orbit slots while the
  // center text reforms; the finished layout then holds, and the stage
  // releases seamlessly as native sticky un-sticks.
  mm.add('(min-width: 992px)', function() {
    var tl = gsap.timeline({
      scrollTrigger: {
        trigger: track,
        start: 'top top',
        end: 'bottom bottom',
        scrub: true,
        invalidateOnRefresh: true
      }
    });

    // Images: rise up from below into their CSS orbit positions, one-by-one.
    // fromTo (explicit endpoints) keeps the reveal refresh-safe under pinning.
    tl.fromTo(imageWrappers,
      { y: 220, autoAlpha: 0 },
      {
        y: 0, autoAlpha: 1,
        ease: 'power2.out', duration: 1, stagger: 0.5
      },
      0
    );

    // Text: scattered characters reassemble, concurrently, finishing last.
    // Function-based from-values apply each char's stable scatter offset.
    tl.fromTo(allChars,
      {
        x: function(i) { return scatter[i].x; },
        y: function(i) { return scatter[i].y; },
        z: function(i) { return scatter[i].z; },
        rotateY: function(i) { return scatter[i].rotateY; },
        rotateX: function(i) { return scatter[i].rotateX; },
        scale: function(i) { return scatter[i].scale; },
        opacity: 0
      },
      {
        x: 0, y: 0, z: 0, rotateY: 0, rotateX: 0, scale: 1, opacity: 1,
        ease: 'power2.out', duration: 2.4,
        stagger: { each: 0.02, from: 'random' }
      },
      0
    );

    // Hold: keep the completed layout pinned and static for the last third of
    // the scroll, so the finished composition is clearly seen before the
    // section releases and glides smoothly into the next section.
    tl.to({}, { duration: tl.duration() * 0.5 });
  });

  // Narrow: no pin/scrub (janky on touch). Static stacked layout with a
  // light fade-in-from-below for the images; text simply shown formed.
  mm.add('(max-width: 991px)', function() {
    gsap.set(allChars, { opacity: 1 });

    gsap.set(imageWrappers, { autoAlpha: 0, y: 40 });
    ScrollTrigger.batch(imageWrappers, {
      start: 'top 88%',
      once: true,
      onEnter: function(batch) {
        gsap.to(batch, {
          autoAlpha: 1, y: 0, duration: 0.6, stagger: 0.12, ease: 'power2.out'
        });
      }
    });
  });
})();
</script>
<% end %>
