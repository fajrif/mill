<%= simple_form_for [:admins, @product], html: { multipart: true } do |f| %>
	<div class="row">
		<div class="col-lg-8">
			<div class="card">
				<div class="card-body">
					<%= f.error_notification %>
					<fieldset>
						<%= f.input :image, as: :file, input_html: { class: "mb-3", accept: "image/gif, image/png, image/jpg, image/jpeg" } %>
						<%= f.input :images, as: :file, input_html: { multiple: true, class: "mb-3", accept: "image/gif, image/png, image/jpg, image/jpeg" } %>
						<%= f.input :banner, as: :file, input_html: { class: "mb-3", accept: "image/gif, image/png, image/jpg, image/jpeg" } %>
						<%= f.input :technical_drawing, as: :file, input_html: { class: "mb-3", accept: "image/gif, image/png, image/jpg, image/jpeg" } %>
						<%= f.input :code, as: :string %>
						<%= f.input :name, as: :string %>
						<%= f.input :caption, as: :string %>
						<%= f.input :short_description, as: :rich_text_area %>
						<%= f.input :description, as: :rich_text_area %>
					</fieldset>
					<%= f.error :base %>
					<div class="form-actions">
						<%= f.button :submit, :class => 'btn btn-secondary' %>
						<% unless @product.new_record? %>
							<%= link_to "Cancel", admins_product_path(@product), :class => 'btn btn-light' %>
						<% else %>
							<%= link_to "Cancel", admins_products_path, :class => 'btn btn-light' %>
						<% end %>
					</div>
				</div>
			</div>
		</div>
		<div class="col-lg-4">
			<div class="row">
				<%= render "admins/shared/error_messages", :target => @product, col: 'col-lg-12' %>
			</div>
		</div>
	</div>
<% end %>

<%= content_for :tail do %>
	<%= stylesheet_link_tag :actiontext, "data-turbo-track": "reload" %>
	<%= javascript_include_tag :trix %>
	<%= javascript_include_tag :actiontext %>
	<%= javascript_include_tag "trix_config.js" %>
<% end %>
