<% title_page("Product details") %>
<div class="row">
	<div class="col-12">
		<div class="card">
			<div class="card-body">
				<table class="table table-hover">
					<tr>
						<td style="width:15%;"><b>ID</b></td>
						<td><%= @product.id %></td>
					</tr>
					<% if @product.image.attached? %>
					<tr>
						<td><b>Image</b></td>
						<td>
							<%= image_tag @product.image.variant(resize_to_limit: [100,100]) %>
						</td>
					</tr>
					<% end %>
					<% if @product.banner.attached? %>
					<tr>
						<td><b>Banner</b></td>
						<td>
							<%= image_tag @product.banner.variant(resize_to_limit: [100,100]) %>
						</td>
					</tr>
					<% end %>
					<% if @product.images.attached? %>
					<tr>
						<td><b>Images</b></td>
						<td>
							<% @product.images.each do |image| %>
								<div class="d-inline-block text-center me-2 mb-2">
									<%= image_tag image.variant(resize_to_limit: [100,100]) %><br/>
									<%= link_to delete_attachment_image_admins_product_path(@product, image.id), :class => "btn btn-danger btn-sm mt-1", :data => { :confirm => 'Are you sure you want to delete this image?' }, :method => :delete do %>
										<i class="ri-delete-bin-fill"></i>
									<% end %>
								</div>
							<% end%>
						</td>
					</tr>
					<% end %>
					<% if @product.technical_drawing.attached? %>
					<tr>
						<td><b>Technical Drawing</b></td>
						<td>
							<%= image_tag @product.technical_drawing.variant(resize_to_limit: [200,200]) %>
						</td>
					</tr>
					<% end %>
					<tr>
						<td><b>Name</b></td>
						<td>
							<h5 class="fs-14 mb-0 text-body"><%= @product.name %></h5>
						</td>
					</tr>
					<tr>
						<td><b>Code</b></td>
						<td><%= @product.code %></td>
					</tr>
					<tr>
						<td><b>Caption</b></td>
						<td>
							<%= @product.caption %>
						</td>
					</tr>
					<tr>
						<td><b>Short Description</b></td>
						<td>
							<%= @product.short_description %>
						</td>
					</tr>
					<tr>
						<td><b>Description</b></td>
						<td>
							<%= @product.description %>
						</td>
					</tr>
				</table>
				<div class="form-actions">
					<%= link_to 'Edit', edit_admins_product_path(@product), :class => 'btn btn-secondary' %>
					<%= link_to 'Destroy', admins_product_path(@product), :data => { :confirm => 'Are you sure?' }, :method => :delete, :class => 'btn btn-danger' %>
					<%= link_to 'View All', admins_products_path, :class => 'btn btn-light' %>
				</div>
			</div>
		</div>
	</div>
</div>

<div class="row">
	<div class="col-12">
		<div class="card">
			<div class="card-header d-flex align-items-center justify-content-between">
				<h5 class="card-title mb-0">Product Openings</h5>
				<button type="button" class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#openingModal_new">
					<i class="ri-add-line align-bottom"></i> Add Opening
				</button>
			</div>
			<div class="card-body">
				<table class="table table-hover">
					<thead>
						<tr>
							<th style="width:20%;">Title</th>
							<th>Description</th>
							<th style="width:15%;">Actions</th>
						</tr>
					</thead>
					<tbody>
						<% @product.product_openings.each do |opening| %>
							<tr>
								<td><%= opening.title %></td>
								<td><%= opening.description.body.present? ? truncate(opening.description.to_plain_text, length: 120) : "-" %></td>
								<td>
									<button type="button" class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#openingModal_<%= opening.id %>">
										<i class="ri-pencil-fill"></i>
									</button>
									<%= link_to admins_product_product_opening_path(@product, opening), :class => "btn btn-danger btn-sm", :data => { :confirm => 'Are you sure you want to delete this opening?' }, :method => :delete do %>
										<i class="ri-delete-bin-fill"></i>
									<% end %>
								</td>
							</tr>
						<% end %>
						<% if @product.product_openings.empty? %>
							<tr>
								<td colspan="3" class="text-center text-muted">No openings added yet.</td>
							</tr>
						<% end %>
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>

<%= render "admins/product_openings/modal", opening: @product.product_openings.new %>
<% @product.product_openings.each do |opening| %>
	<%= render "admins/product_openings/modal", opening: opening %>
<% end %>

<%= content_for :tail do %>
	<%= stylesheet_link_tag :actiontext, "data-turbo-track": "reload" %>
	<%= javascript_include_tag :trix %>
	<%= javascript_include_tag :actiontext %>
	<%= javascript_include_tag "trix_config.js" %>
<% end %>
