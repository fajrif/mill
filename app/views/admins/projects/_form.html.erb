<%= simple_form_for [:admins, @project], html: { multipart: true } do |f| %>
	<div class="row">
		<div class="col-lg-8">
			<div class="card">
				<div class="card-body">
					<%= f.error_notification %>
					<fieldset>
						<%= f.input :image, as: :file, input_html: { class: "mb-3", accept: "image/gif, image/png, image/jpg, image/jpeg" } %>
						<%= f.input :images, as: :file, input_html: { multiple: true, class: "mb-3", accept: "image/gif, image/png, image/jpg, image/jpeg" } %>
						<%= f.input :banner, as: :file, input_html: { class: "mb-3", accept: "image/gif, image/png, image/jpg, image/jpeg" } %>
						<%= f.input :name, as: :string %>
						<%= f.input :caption, as: :string %>
						<%= f.input :short_description, as: :text %>
						<%= f.input :description, as: :text %>
					</fieldset>
					<%= f.error :base %>
					<div class="form-actions">
						<%= f.button :submit, :class => 'btn btn-secondary' %>
						<% unless @project.new_record? %>
							<%= link_to "Cancel", admins_project_path(@project), :class => 'btn btn-light' %>
						<% else %>
							<%= link_to "Cancel", admins_projects_path, :class => 'btn btn-light' %>
						<% end %>
					</div>
				</div>
			</div>
		</div>
		<div class="col-lg-4">
			<div class="row">
				<%= render "admins/shared/error_messages", :target => @project, col: 'col-lg-12' %>
				<div class="col-lg-12">
					<div class="card">
						<div class="card-header">
							<h5 class="card-title mb-0">Settings</h5>
						</div>
						<div class="card-body">
							<%= f.input :published_date, as: :string, input_html: { class: "datetimepicker", value: get_input_date_value(f.object.published_date) } %>
							<%= f.input :status, as: :select, collection: get_published_status, value_method: :first, label_method: :last %>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
<% end %>
